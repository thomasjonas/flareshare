# Session signing key — generate with: openssl rand -hex 32
SESSION_SECRET=

# GitHub OAuth app — create one at https://github.com/settings/developers
# Callback URL: http://localhost:5173/auth/callback (dev) or https://<your-domain>/auth/callback (prod)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Numeric GitHub user ID that is allowed to upload
# Find yours at: https://api.github.com/users/<your-username>
ALLOWED_GITHUB_ID=

# Cloudflare R2 — create an API token with Object Read & Write permissions
# Account ID is found on the Cloudflare dashboard homepage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
